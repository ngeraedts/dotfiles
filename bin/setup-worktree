#!/bin/sh
set -eu

usage() {
  cat << 'EOF'
usage: setup-worktree [branch-name] [base-branch]

Creates or reuses a git worktree for the current repository and opens it in a
new Zed window.

Arguments:
  branch-name  Git branch name to create or open. If omitted, an interactive
               picker is shown when possible, otherwise a terminal prompt is used.
  base-branch  Base branch to create from when the branch does not yet exist.
               If omitted, the script will try origin/HEAD, then main, then master,
               then develop.

Examples:
  setup-worktree nick/HIIVE-123-do-a-thing
  setup-worktree nick/HIIVE-123-do-a-thing main
EOF
}

trust_with_mise() {
  worktree_path="$1"

  if ! command -v mise > /dev/null 2>&1; then
    return 0
  fi

  mise trust "$worktree_path" > /dev/null 2>&1 || true
}

copy_directory_contents() {
  source_dir="$1"
  destination_dir="$2"

  if [ ! -d "$source_dir" ]; then
    return 1
  fi

  mkdir -p "$destination_dir"

  if command -v rsync > /dev/null 2>&1; then
    rsync -a "$source_dir"/ "$destination_dir"/ > /dev/null 2>&1
    return 0
  fi

  cp -R "$source_dir"/. "$destination_dir"/
}

copy_file_if_present() {
  source_file="$1"
  destination_file="$2"

  if [ ! -f "$source_file" ]; then
    return 1
  fi

  destination_dir="$(dirname "$destination_file")"
  mkdir -p "$destination_dir"
  cp "$source_file" "$destination_file"
}

upsert_env_local_value() {
  env_file="$1"
  key="$2"
  value="$3"

  if [ -f "$env_file" ]; then
    if grep -q "^${key}=" "$env_file"; then
      tmp_file="$(mktemp)"
      sed "s|^${key}=.*|${key}=${value}|" "$env_file" > "$tmp_file"
      mv "$tmp_file" "$env_file"
      return 0
    fi
  fi

  {
    if [ -f "$env_file" ] && [ -s "$env_file" ]; then
      printf '\n'
    fi
    printf '%s=%s\n' "$key" "$value"
  } >> "$env_file"
}

copy_project_artifacts() {
  source_root="$1"
  destination_root="$2"
  worktree_name="$3"
  copied_any=0

  if [ -f "$source_root/mix.exs" ]; then
    echo "Warming Elixir artifacts..."
    if copy_directory_contents "$source_root/deps" "$destination_root/deps"; then
      echo "  Copied deps/"
      copied_any=1
    fi
    if copy_directory_contents "$source_root/_build" "$destination_root/_build"; then
      echo "  Copied _build/"
      copied_any=1
    fi

    upsert_env_local_value "$destination_root/.env.local" "TEST_DB_SUFFIX" "$worktree_name"
    echo "  Set TEST_DB_SUFFIX in .env.local"
    copied_any=1
  fi

  if [ -f "$source_root/package.json" ]; then
    echo "Warming Node artifacts..."
    if copy_directory_contents "$source_root/node_modules" "$destination_root/node_modules"; then
      echo "  Copied node_modules/"
      copied_any=1
    fi
  fi

  if [ -f "$source_root/Cargo.toml" ]; then
    echo "Warming Rust artifacts..."
    if copy_directory_contents "$source_root/target" "$destination_root/target"; then
      echo "  Copied target/"
      copied_any=1
    fi
  fi

  if [ -f "$source_root/Gemfile" ]; then
    echo "Warming Ruby artifacts..."
    if copy_directory_contents "$source_root/vendor/bundle" "$destination_root/vendor/bundle"; then
      echo "  Copied vendor/bundle/"
      copied_any=1
    fi
  fi

  if copy_file_if_present "$source_root/.env" "$destination_root/.env"; then
    echo "  Copied .env"
    copied_any=1
  fi

  if [ "$copied_any" -eq 0 ]; then
    echo "No dependency or build artifacts found to warm."
  fi
}

prompt_for_branch_name() {
  if [ ! -t 0 ]; then
    echo "No branch name provided and no interactive terminal available." >&2
    exit 1
  fi

  printf 'Enter branch name: ' >&2
  IFS= read -r user_input
  printf '%s\n' "$user_input"
}

list_local_branches() {
  git for-each-ref \
    --format='%(refname:short)' \
    --sort=-committerdate \
    refs/heads
}

find_fzf() {
  if command -v fzf > /dev/null 2>&1; then
    resolved_path="$(command -v fzf)"
    printf '%s\n' "$resolved_path"
    return 0
  fi

  for candidate in \
    /opt/homebrew/bin/fzf \
    /usr/local/bin/fzf \
    /bin/fzf \
    /usr/bin/fzf; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

pick_branch_name() {
  if [ ! -t 0 ]; then
    prompt_for_branch_name
    return 0
  fi

  fzf_path="$(find_fzf || true)"

  if [ -n "$fzf_path" ]; then
    branch_list_file="$(mktemp)"
    trap 'rm -f "$branch_list_file"' EXIT HUP INT TERM

    {
      printf '%s\n' '[type a new branch name]'
      list_local_branches
    } > "$branch_list_file"

    branch_count="$(wc -l < "$branch_list_file" | tr -d ' ')"

    selection_file="$(mktemp)"
    trap 'rm -f "$branch_list_file" "$selection_file"' EXIT HUP INT TERM

    set +e
    "$fzf_path" \
      --prompt='Branch > ' \
      --height=40% \
      --layout=reverse \
      --border \
      --print-query \
      --query='' \
      < "$branch_list_file" > "$selection_file"
    fzf_status="$?"
    set -e

    selection="$(cat "$selection_file")"

    rm -f "$branch_list_file" "$selection_file"
    trap - EXIT HUP INT TERM

    query="$(printf '%s\n' "$selection" | sed -n '1p')"
    choice="$(printf '%s\n' "$selection" | sed -n '2p')"

    if [ -z "$choice" ] && [ -n "$query" ]; then
      choice="$query"
    fi

    if [ "$choice" = "[type a new branch name]" ]; then
      printf '%s\n' "$query"
      return 0
    fi

    if [ -n "$choice" ]; then
      printf '%s\n' "$choice"
      return 0
    fi

    exit "$fzf_status"
  fi

  prompt_for_branch_name
}

require_command() {
  if ! command -v "$1" > /dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

sanitize_branch_name() {
  printf '%s' "$1" |
    tr '/[:space:]' '--' |
    tr '[:upper:]' '[:lower:]' |
    tr -cd '[:alnum:]._-' |
    sed 's/--*/-/g; s/^-//; s/-$//'
}

resolve_base_branch() {
  if [ -n "${1:-}" ]; then
    printf '%s\n' "$1"
    return 0
  fi

  remote_head_ref="$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2> /dev/null || true)"

  if [ -n "$remote_head_ref" ]; then
    printf '%s\n' "${remote_head_ref#refs/remotes/origin/}"
    return 0
  fi

  for candidate in main master develop; do
    if git show-ref --verify --quiet "refs/heads/$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi

    if git ls-remote --exit-code --heads origin "$candidate" > /dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  echo "Could not determine a base branch. Pass one explicitly." >&2
  exit 1
}

ensure_branch_available() {
  branch_name="$1"
  base_branch="$2"

  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    return 0
  fi

  if git ls-remote --exit-code --heads origin "$branch_name" > /dev/null 2>&1; then
    git fetch origin "$branch_name:$branch_name" > /dev/null 2>&1
    return 0
  fi

  if ! git show-ref --verify --quiet "refs/heads/$base_branch"; then
    git fetch origin "$base_branch:$base_branch" > /dev/null 2>&1
  fi
}

worktree_exists_at_path() {
  worktree_path="$1"
  [ -d "$worktree_path/.git" ] || [ -f "$worktree_path/.git" ]
}

branch_is_checked_out_elsewhere() {
  branch_name="$1"

  git worktree list --porcelain |
    awk '
      /^branch / { current_branch = substr($0, 8) }
      /^worktree / { current_worktree = substr($0, 10) }
      /^$/ {
        if (current_branch == "refs/heads/'"$branch_name"'") {
          print current_worktree
          exit
        }
        current_branch = ""
        current_worktree = ""
      }
      END {
        if (current_branch == "refs/heads/'"$branch_name"'") {
          print current_worktree
        }
      }
    '
}

open_in_zed() {
  worktree_path="$1"

  if command -v zed > /dev/null 2>&1; then
    zed "$worktree_path"
    return 0
  fi

  open -a Zed "$worktree_path"
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

require_command git
require_command open

branch_name="${1:-}"

if [ -z "$branch_name" ]; then
  branch_name="$(pick_branch_name)"
fi

if [ -z "$branch_name" ]; then
  echo "No branch name provided." >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel 2> /dev/null || true)"

if [ -z "$repo_root" ]; then
  echo "Run this script from inside a git repository." >&2
  exit 1
fi

base_branch="$(resolve_base_branch "${2:-}")"
repo_name="$(basename "$repo_root")"
parent_dir="$(dirname "$repo_root")"
worktrees_dir="$parent_dir/${repo_name}-worktrees"
safe_name="$(sanitize_branch_name "$branch_name")"
worktree_dir_name="${repo_name}--${safe_name}"
worktree_path="$worktrees_dir/$worktree_dir_name"

if [ -z "$safe_name" ]; then
  echo "Could not derive a safe folder name from branch: $branch_name" >&2
  exit 1
fi

mkdir -p "$worktrees_dir"

if worktree_exists_at_path "$worktree_path"; then
  echo "Reusing existing worktree: $worktree_path"
  trust_with_mise "$worktree_path"
  open_in_zed "$worktree_path"
  exit 0
fi

existing_worktree="$(branch_is_checked_out_elsewhere "$branch_name" || true)"

if [ -n "$existing_worktree" ]; then
  echo "Branch is already checked out in another worktree: $existing_worktree" >&2
  exit 1
fi

ensure_branch_available "$branch_name" "$base_branch"

if git show-ref --verify --quiet "refs/heads/$branch_name"; then
  git worktree add "$worktree_path" "$branch_name"
else
  git worktree add "$worktree_path" -b "$branch_name" "$base_branch"
fi

echo "Warming new worktree from $repo_root..."
copy_project_artifacts "$repo_root" "$worktree_path" "$safe_name"
trust_with_mise "$worktree_path"
open_in_zed "$worktree_path"
