#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
usage: git-worktree-prune-merged

Removes git worktrees whose branches have already been merged upstream and whose
upstream tracking refs are gone.

This is intended to complement `ggbda` by cleaning up stale worktrees after
their branches have been merged and deleted on the remote.

Behavior:
  - fetches remotes with prune
  - finds non-main worktrees with local branches
  - removes only worktrees whose branch upstream is marked gone
  - skips the current worktree
  - skips the main repository worktree

Examples:
  git-worktree-prune-merged
EOF
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

require_command git

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [ -z "$repo_root" ]; then
  echo "Run this script from inside a git repository." >&2
  exit 1
fi

current_worktree="$(pwd -P)"

git fetch --all --prune >/dev/null 2>&1 || true

git worktree list --porcelain | awk '
  /^worktree / { worktree = substr($0, 10) }
  /^branch / { branch = substr($0, 8) }
  /^$/ {
    if (worktree != "" && branch ~ /^refs\/heads\//) {
      print worktree "\t" substr(branch, 12)
    }
    worktree = ""
    branch = ""
  }
  END {
    if (worktree != "" && branch ~ /^refs\/heads\//) {
      print worktree "\t" substr(branch, 12)
    }
  }
' | while IFS='	' read -r worktree_path branch_name; do
  if [ "$worktree_path" = "$repo_root" ]; then
    continue
  fi

  if [ "$worktree_path" = "$current_worktree" ]; then
    echo "Skipping current worktree: $worktree_path" >&2
    continue
  fi

  branch_status="$(git for-each-ref --format='%(upstream:track)' "refs/heads/$branch_name" 2>/dev/null || true)"

  if [ "$branch_status" != "[gone]" ]; then
    continue
  fi

  echo "Removing merged worktree: $worktree_path ($branch_name)"
  git worktree remove "$worktree_path"
done
