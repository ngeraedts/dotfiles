#!/bin/sh
set -eu

usage() {
  cat << 'EOF'
usage: remove-worktree

Interactively selects a git worktree to remove using fzf.

Behavior:
  - lists non-main worktrees for the current repository
  - skips the current worktree
  - lets you select a worktree with fzf
  - removes the selected worktree with `git worktree remove`
  - prompts to force-remove dirty worktrees when needed
  - drops the Elixir test database for the worktree when `TEST_DB_SUFFIX` is set

Examples:
  remove-worktree
EOF
}

require_command() {
  if ! command -v "$1" > /dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

read_env_value() {
  env_file="$1"
  key="$2"

  if [ ! -f "$env_file" ]; then
    return 1
  fi

  awk -F '=' -v key="$key" '
    $1 == key {
      value = substr($0, index($0, "=") + 1)
      print value
      exit
    }
  ' "$env_file"
}

drop_test_database() {
  worktree_path="$1"

  test_db_suffix="$(read_env_value "$worktree_path/.env.local" "TEST_DB_SUFFIX" || true)"

  if [ -z "$test_db_suffix" ]; then
    return 0
  fi

  database_name="hiive_test${test_db_suffix}"

  if ! command -v dropdb > /dev/null 2>&1; then
    echo "Skipping test database cleanup for $database_name: dropdb not found." >&2
    return 0
  fi

  echo "Dropping test database: $database_name"
  dropdb --if-exists "$database_name"
}

confirm_force_remove() {
  worktree_path="$1"
  branch_name="$2"

  if [ ! -t 0 ]; then
    echo "Worktree is dirty and no interactive terminal is available to confirm force removal." >&2
    return 1
  fi

  printf 'Worktree "%s" (%s) has modified or untracked files. Force remove? [y/N] ' "$worktree_path" "$branch_name" > /dev/tty
  IFS= read -r answer < /dev/tty || true

  case "$answer" in
  y | Y | yes | YES | Yes)
    return 0
    ;;
  *)
    echo "Cancelled."
    return 1
    ;;
  esac
}

remove_worktree() {
  worktree_path="$1"
  branch_name="$2"

  echo "Removing worktree: $worktree_path ($branch_name)"

  set +e
  remove_output="$(git worktree remove "$worktree_path" 2>&1)"
  remove_status="$?"
  set -e

  if [ "$remove_status" -eq 0 ]; then
    printf '%s\n' "$remove_output"
    return 0
  fi

  printf '%s\n' "$remove_output" >&2

  case "$remove_output" in
  *"contains modified or untracked files, use --force to delete it"*)
    if ! confirm_force_remove "$worktree_path" "$branch_name"; then
      return 1
    fi

    echo "Force removing worktree: $worktree_path ($branch_name)"
    git worktree remove --force "$worktree_path"
    return 0
    ;;
  *)
    return "$remove_status"
    ;;
  esac
}

find_fzf() {
  if command -v fzf > /dev/null 2>&1; then
    command -v fzf
    return 0
  fi

  for candidate in \
    /opt/homebrew/bin/fzf \
    /usr/local/bin/fzf \
    /bin/fzf \
    /usr/bin/fzf; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

list_removable_worktrees() {
  repo_root="$1"
  current_worktree="$2"

  git worktree list --porcelain | awk -v repo_root="$repo_root" -v current_worktree="$current_worktree" '
    /^worktree / { worktree = substr($0, 10) }
    /^branch / { branch = substr($0, 8) }
    /^detached$/ { detached = 1 }
    /^$/ {
      if (worktree != "" && worktree != repo_root && worktree != current_worktree && detached != 1 && branch ~ /^refs\/heads\//) {
        branch_name = substr(branch, 12)
        worktree_name = worktree
        sub(/^.*\//, "", worktree_name)
        printf "%s\t%s\t%s\n", branch_name, worktree_name, worktree
      }
      worktree = ""
      branch = ""
      detached = 0
    }
    END {
      if (worktree != "" && worktree != repo_root && worktree != current_worktree && detached != 1 && branch ~ /^refs\/heads\//) {
        branch_name = substr(branch, 12)
        worktree_name = worktree
        sub(/^.*\//, "", worktree_name)
        printf "%s\t%s\t%s\n", branch_name, worktree_name, worktree
      }
    }
  '
}

pick_worktree() {
  repo_root="$1"
  current_worktree="$2"
  fzf_path="$3"

  worktree_list_file="$(mktemp)"
  selection_file="$(mktemp)"
  trap 'rm -f "$worktree_list_file" "$selection_file"' EXIT HUP INT TERM

  list_removable_worktrees "$repo_root" "$current_worktree" > "$worktree_list_file"

  if [ ! -s "$worktree_list_file" ]; then
    echo "No removable worktrees found." >&2
    exit 1
  fi

  set +e
  "$fzf_path" \
    --prompt='Remove worktree > ' \
    --height=40% \
    --layout=reverse \
    --border \
    --no-multi \
    --preview='' \
    --delimiter='\t' \
    --with-nth=1,2,3 \
    < "$worktree_list_file" > "$selection_file"
  fzf_status="$?"
  set -e

  if [ "$fzf_status" -ne 0 ]; then
    exit "$fzf_status"
  fi

  selection="$(cat "$selection_file")"

  rm -f "$worktree_list_file" "$selection_file"
  trap - EXIT HUP INT TERM

  if [ -z "$selection" ]; then
    echo "No worktree selected." >&2
    exit 1
  fi

  branch_name="$(printf '%s\n' "$selection" | awk -F '\t' '{print $1}')"
  worktree_name="$(printf '%s\n' "$selection" | awk -F '\t' '{print $2}')"
  worktree_path="$(printf '%s\n' "$selection" | awk -F '\t' '{print $3}')"

  printf '%s\t%s\t%s\n' "$branch_name" "$worktree_name" "$worktree_path"
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

require_command git

fzf_path="$(find_fzf || true)"

if [ -z "$fzf_path" ]; then
  echo "Missing required command: fzf" >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel 2> /dev/null || true)"

if [ -z "$repo_root" ]; then
  echo "Run this script from inside a git repository." >&2
  exit 1
fi

current_worktree="$(pwd -P)"

set +e
selection="$(pick_worktree "$repo_root" "$current_worktree" "$fzf_path")"
pick_status="$?"
set -e

if [ "$pick_status" -ne 0 ]; then
  exit "$pick_status"
fi

branch_name="$(printf '%s\n' "$selection" | awk -F '\t' '{print $1}')"
worktree_name="$(printf '%s\n' "$selection" | awk -F '\t' '{print $2}')"
worktree_path="$(printf '%s\n' "$selection" | awk -F '\t' '{print $3}')"

drop_test_database "$worktree_path"
remove_worktree "$worktree_path" "$branch_name"
